        <key>HOME</key>
        <string>/Users/sabyasachipurkayastha</string>
    </dict>

    <key>RunAtLoad</key>
    <false/>

    <key>WorkingDirectory</key>
    <string>/Users/sabyasachipurkayastha/proj_claude/lottery_by_chance</string>
</dict>
</plist>
